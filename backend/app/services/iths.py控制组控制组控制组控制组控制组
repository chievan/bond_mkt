class ITHSClient:
    def __init__(self, refresh_token: str):
        self.refresh_token = refresh_token
        self.access_token = None
        self.token_expiry = None
        self.base_url = "https://quantapi.51ifind.com/api/v1"

    async def get_access_token(self):
        # If token is still valid (using 6 days as buffer instead of 7)
        if self.access_token and self.token_expiry and datetime.now() < self.token_expiry:
            return self.access_token

        url = f"{self.base_url}/get_access_token"
        headers = {
            "Content-Type": "application/json",
            "refresh_token": self.refresh_token
        }
        
        async with httpx.AsyncClient() as client:
            try:
                response = await client.post(url, headers=headers)
                data = response.json()
                if data.get("errorcode") == 0:
                    self.access_token = data["data"]["access_token"]
                    # Usually expires in 7 days, we'll refresh every 6 days
                    self.token_expiry = datetime.now() + timedelta(days=6)
                    return self.access_token
                else:
                    raise Exception(f"Failed to get access token: {data.get('errmsg')}")
            except Exception as e:
                print(f"Error getting access token: {e}")
                return None

    async def fetch_edb_data(self, indicators: List[str], start_date: str, end_date: str):
        token = await self.get_access_token()
        if not token:
            return None

        url = f"{self.base_url}/edb_query"
        headers = {
            "Content-Type": "application/json",
            "access_token": token
        }
        payload = {
            "indicators": ",".join(indicators),
            "startdate": start_date,
            "enddate": end_date
        }

        async with httpx.AsyncClient() as client:
            try:
                response = await client.post(url, json=payload, headers=headers)
                return response.json()
            except Exception as e:
                print(f"Error fetching EDB data: {e}")
                return None

