async def sync_iths_to_db(db: Session):
    """
    Real synchronization logic using iTHS API.
    """
    data = await fetch_latest_bond_data()
    if "error" in data:
        return False

    for entry in data:
        date_obj = datetime.strptime(entry["date"], "%Y-%m-%d").date()
        
        # Sync Yields
        yield_entry = BondYield(
            date=date_obj,
            y1=entry.get("y1"),
            y2=entry.get("y2"),
            y3=entry.get("y3"),
            y5=entry.get("y5"),
            y7=entry.get("y7"),
            y10=entry.get("y10"),
            y30=entry.get("y30")
        )
        db.merge(yield_entry)

        # Sync Spreads (Calculated)
        spread_entry = BondSpread(
            date=date_obj,
            s10y_2y=entry.get("y10") - entry.get("y2") if entry.get("y10") and entry.get("y2") else None,
            s5y_3y=entry.get("y5") - entry.get("y3") if entry.get("y5") and entry.get("y3") else None,
            # ... add more
        )
        db.merge(spread_entry)
    
    db.commit()
