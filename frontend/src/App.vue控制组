<script setup>
import { ref, onMounted, computed } from 'vue'
import axios from 'axios'
import * as echarts from 'echarts'

const yields = ref([])
const spreads = ref([])
const sheets = ref([])
const currentSheet = ref('收益率曲线')
const sheetData = ref([])
const yieldChart = ref(null)
const spreadChart = ref(null)

const API_BASE = 'http://localhost:8000'

const fetchData = async () => {
  try {
    const [yRes, sRes, sheetsRes] = await Promise.all([
      axios.get(`${API_BASE}/yields`),
      axios.get(`${API_BASE}/spreads`),
      axios.get(`${API_BASE}/sheets`)
    ])
    yields.value = yRes.data
    spreads.value = sRes.data
    sheets.value = sheetsRes.data
    
    if (sheets.value.length) {
      currentSheet.value = sheets.value.includes('收益率曲线') ? '收益率曲线' : sheets.value[0]
      await fetchSheetData(currentSheet.value)
    }
    initCharts()
  } catch (err) {
    console.error('Failed to fetch data', err)
  }
}

const fetchSheetData = async (name) => {
  currentSheet.value = name
  try {
    const res = await axios.get(`${API_BASE}/sheets/${encodeURIComponent(name)}`)
    sheetData.value = res.data
  } catch (err) {
    console.error('Failed to fetch sheet data', err)
  }
}

const tableHeaders = computed(() => {
  if (!sheetData.value.length) return []
  return Object.keys(sheetData.value[0]).filter(h => !h.startsWith('Unnamed'))
})

const initCharts = () => {
  if (!yields.value.length) return

  const yc = echarts.init(yieldChart.value)
  const latest = yields.value[0]
  yc.setOption({
    backgroundColor: 'transparent',
    tooltip: { trigger: 'axis' },
    xAxis: {
      type: 'category',
      data: ['1Y', '2Y', '3Y', '5Y', '7Y', '10Y', '30Y'],
      axisLine: { lineStyle: { color: '#64748b' } }
    },
    yAxis: {
      type: 'value',
      name: 'Yield (%)',
      scale: true,
      axisLine: { lineStyle: { color: '#64748b' } },
      splitLine: { lineStyle: { color: '#334155' } }
    },
    series: [{
      data: [latest.y1, latest.y2, latest.y3, latest.y5, latest.y7, latest.y10, latest.y30],
      type: 'line',
      smooth: true,
      symbolSize: 8,
      itemStyle: { color: '#38bdf8' },
      areaStyle: {
        color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
          { offset: 0, color: 'rgba(56, 189, 248, 0.3)' },
          { offset: 1, color: 'rgba(56, 189, 248, 0)' }
        ])
      }
    }]
  })

  const sc = echarts.init(spreadChart.value)
  const history = [...spreads.value].reverse()
  sc.setOption({
    backgroundColor: 'transparent',
    tooltip: { trigger: 'axis' },
    legend: { textStyle: { color: '#cbd5e1' } },
    xAxis: {
      type: 'category',
      data: history.map(s => s.date),
      axisLine: { lineStyle: { color: '#64748b' } }
    },
    yAxis: {
      type: 'value',
      name: 'BP',
      axisLine: { lineStyle: { color: '#64748b' } },
      splitLine: { lineStyle: { color: '#334155' } }
    },
    series: [
      {
        name: '10Y-2Y',
        data: history.map(s => s.s10y_2y),
        type: 'line',
        itemStyle: { color: '#818cf8' }
      },
      {
        name: '10Y-7Y',
        data: history.map(s => s.s10y_7y),
        type: 'line',
        itemStyle: { color: '#fb7185' }
      }
    ]
  })
}

onMounted(() => {
  fetchData()
  window.addEventListener('resize', () => {
    echarts.getInstanceByDom(yieldChart.value)?.resize()
    echarts.getInstanceByDom(spreadChart.value)?.resize()
  })
})
</script>

<template>
  <div class="min-h-screen p-6 max-w-full lg:px-12">
    <header class="flex justify-between items-center mb-10">
      <div>
        <h1 class="text-4xl font-bold bg-gradient-to-r from-bond-primary to-bond-secondary bg-clip-text text-transparent">
          债券市场跟踪系统
        </h1>
        <p class="text-slate-400 mt-2 text-lg">Bond Market Analytics & AI Assistant v2.0</p>
      </div>
      <div class="flex gap-4">
        <button @click="fetchData" class="btn-primary flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
          刷新
        </button>
      </div>
    </header>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
      <!-- Main Content -->
      <div class="xl:col-span-3 space-y-8">
        <!-- Charts Row -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="glass-card p-8">
            <h2 class="text-xl font-semibold mb-6 text-slate-200 border-l-4 border-bond-primary pl-4">最新国债收益率曲线</h2>
            <div ref="yieldChart" class="h-80 w-full"></div>
          </div>
          
          <div class="glass-card p-8">
            <h2 class="text-xl font-semibold mb-6 text-slate-200 border-l-4 border-bond-secondary pl-4">关键利差历史走势</h2>
            <div ref="spreadChart" class="h-80 w-full"></div>
          </div>
        </div>

        <!-- Dynamic Sheets Table -->
        <div class="glass-card p-8">
          <h2 class="text-xl font-semibold mb-6 text-slate-200">数据报表中心</h2>
          <div class="flex items-center gap-3 overflow-x-auto mb-8 pb-4 border-b border-slate-700/50 no-scrollbar">
            <button 
              v-for="sheet in sheets" 
              :key="sheet"
              @click="fetchSheetData(sheet)"
              :class="[
                'px-5 py-2.5 rounded-full transition-all whitespace-nowrap border text-sm font-medium',
                currentSheet === sheet 
                  ? 'bg-bond-primary/20 text-bond-primary border-bond-primary' 
                  : 'text-slate-400 border-transparent hover:bg-slate-800'
              ]"
            >
              {{ sheet }}
            </button>
          </div>

          <div class="overflow-x-auto rounded-xl border border-slate-700/50 shadow-inner">
            <table class="w-full text-sm text-left border-collapse">
              <thead class="text-xs uppercase bg-slate-800/80 sticky top-0 backdrop-blur-sm">
                <tr>
                  <th v-for="header in tableHeaders" :key="header" class="px-6 py-4 font-semibold text-slate-300 border-b border-slate-700">
                    {{ header }}
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-700/30">
                <tr v-for="(row, i) in sheetData" :key="i" class="hover:bg-bond-primary/5 transition-colors group">
                  <td v-for="header in tableHeaders" :key="header" class="px-6 py-4 text-slate-400 group-hover:text-slate-200 border-b border-slate-800/50">
                    {{ row[header] }}
                  </td>
                </tr>
              </tbody>
            </table>
            <div v-if="!sheetData.length" class="text-center py-20 text-slate-500 italic">
              <div class="animate-spin inline-block w-8 h-8 border-4 border-bond-primary border-t-transparent rounded-full mb-4"></div>
              <p>正在读取 Excel 表格数据...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- AI Sidebar -->
      <div class="xl:col-span-1">
        <div class="glass-card sticky top-6 flex flex-col p-8 min-h-[700px] border-bond-primary/20 shadow-bond-primary/5 shadow-2xl">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-xl font-bold flex items-center gap-3">
              <div class="relative">
                <span class="absolute inset-0 bg-bond-primary blur-sm rounded-full animate-pulse"></span>
                <span class="relative w-3 h-3 bg-bond-primary rounded-full block"></span>
              </div>
              DeepSeek AI 分析师
            </h2>
          </div>
          
          <div class="flex-1 overflow-y-auto mb-6 space-y-5 pr-2 custom-scrollbar">
            <div class="bg-slate-800/40 p-4 rounded-2xl border border-slate-700/50 leading-relaxed text-slate-300">
              你好！我是你的债市专职助手。我已经读取了 Excel 中的 <span class="text-bond-primary font-bold">{{ sheets.length }}</span> 个数据表。
              <br><br>
              你可以问我关于收益率、利差或基差的任何问题。
            </div>
          </div>

          <div class="relative mt-auto">
            <textarea 
              rows="3"
              placeholder="输入你的问题，例如：分析一下当前的收益率曲线形状..." 
              class="w-full bg-slate-900/50 border border-slate-700 rounded-2xl px-5 py-4 text-sm focus:outline-none focus:border-bond-primary focus:ring-1 focus:ring-bond-primary transition-all resize-none shadow-inner"
            ></textarea>
            <button class="absolute right-4 bottom-4 p-2 bg-bond-primary text-white rounded-xl hover:scale-105 transition-transform shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

