      </nav>

      <div class="absolute bottom-8 left-6 right-6">
        <div class="glass-card p-4 text-xs text-slate-500 border-slate-800/50">
          <p class="mb-2">数据同步状态</p>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
            <span class="text-slate-300">同花顺接口已连接 (Mock)</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="ml-64 p-8 min-h-screen">
      <header class="flex justify-between items-end mb-10">
        <div>
          <nav class="text-sm text-slate-500 mb-2">工作空间 / 数据监控 / {{ currentSheet }}</nav>
          <h2 class="text-4xl font-bold text-white tracking-tight">{{ currentSheet }}</h2>
        </div>
        <div class="flex gap-3">
          <button @click="fetchData" class="btn-primary flex items-center gap-2 shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
            同步最新数据
          </button>
        </div>
      </header>

      <div class="grid grid-cols-1 gap-12">
        <!-- Dashboard Blocks for each Sub-Table -->
        <div v-for="(table, idx) in sheetData" :key="idx" class="space-y-6">
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-semibold text-slate-200 flex items-center gap-3">
              <span class="w-2 h-8 bg-bond-primary rounded-full"></span>
              {{ table.title || '市场明细数据' }}
            </h3>
            <div class="text-xs text-slate-500 bg-slate-800/50 px-3 py-1 rounded-full border border-slate-700/50">
              共 {{ table.data.length }} 条记录
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left: Table -->
            <div class="lg:col-span-8 glass-card overflow-hidden border-slate-800/50 shadow-2xl">
              <div class="overflow-x-auto max-h-[600px] custom-scrollbar">
                <table class="w-full text-sm text-left border-collapse">
                  <thead class="sticky top-0 z-10">
                    <tr class="bg-slate-800/90 backdrop-blur-md">
                      <th v-for="header in Object.keys(table.data[0] || {})" :key="header" class="px-6 py-4 font-bold text-slate-300 border-b border-slate-700 whitespace-nowrap">
                        {{ header }}
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-800/50">
                    <tr v-for="(row, i) in table.data" :key="i" class="hover:bg-bond-primary/5 transition-colors group">
                      <td 
                        v-for="header in Object.keys(table.data[0] || {})" 
                        :key="header" 
                        :class="[
                          'px-6 py-4 text-slate-400 group-hover:text-slate-200 border-b border-slate-900/20 whitespace-nowrap transition-all',
                          getStatusColor(row[header], header)
