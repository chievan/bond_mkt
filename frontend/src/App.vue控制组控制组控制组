                      >
                        {{ row[header] }}
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Right: Dynamic Chart -->
            <div class="lg:col-span-4 space-y-6">
              <div class="glass-card p-6 h-full border-slate-800/50 shadow-xl flex flex-col">
                <div class="dynamic-chart flex-1 min-h-[350px]"></div>
                <div class="mt-4 p-4 bg-slate-800/30 rounded-xl border border-slate-700/30">
                  <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">AI 智能解读</h4>
                  <p class="text-sm text-slate-300 leading-relaxed italic">
                    当前 {{ table.title }} 显示指标处于历史较高分位，建议关注流动性溢价。
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div v-if="!sheetData.length" class="flex flex-col items-center justify-center py-40 text-slate-500">
          <div class="w-16 h-16 border-4 border-bond-primary/20 border-t-bond-primary rounded-full animate-spin mb-6"></div>
          <p class="text-lg font-medium animate-pulse">正在从 Excel 镜像中提取高维数据...</p>
        </div>
      </div>
    </main>

    <!-- Floating AI Bubble -->
    <div class="fixed right-8 bottom-8 z-30">
      <button class="w-16 h-16 bg-bond-primary rounded-full shadow-2xl shadow-bond-primary/40 flex items-center justify-center hover:scale-110 transition-transform active:scale-95 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
      </button>
