  <div class="min-h-screen bg-[#0f172a] text-slate-200 font-sans">
    <!-- Sidebar Navigation -->
    <aside class="fixed left-0 top-0 h-full w-64 bg-slate-900/50 border-r border-slate-800 p-6 z-20 backdrop-blur-xl">
      <div class="flex items-center gap-3 mb-12">
        <div class="w-10 h-10 bg-bond-primary rounded-xl flex items-center justify-center shadow-lg shadow-bond-primary/20">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="m13 13 9 9"/></svg>
        </div>
        <h1 class="text-xl font-bold tracking-tight">债市监控</h1>
      </div>

      <nav class="space-y-2">
        <button 
          v-for="sheet in sheets" 
