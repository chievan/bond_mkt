          @click="fetchSheetData(sheet)"
          :class="[
            'w-full text-left px-4 py-3 rounded-xl transition-all flex items-center gap-3 group',
            currentSheet === sheet 
              ? 'bg-bond-primary/10 text-bond-primary border border-bond-primary/20 shadow-lg shadow-bond-primary/5' 
              : 'text-slate-400 hover:bg-slate-800/50 hover:text-slate-200 border border-transparent'
          ]"
        >
          <span class="w-1.5 h-1.5 rounded-full transition-transform group-hover:scale-150" :class="currentSheet === sheet ? 'bg-bond-primary shadow-[0_0_8px_rgba(56,189,248,0.8)]' : 'bg-slate-600'"></span>
          {{ sheet }}
