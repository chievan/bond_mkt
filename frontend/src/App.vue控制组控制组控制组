<script setup>
import { ref, onMounted, computed, watch, nextTick } from 'vue'
import axios from 'axios'
import * as echarts from 'echarts'

const yields = ref([])
const spreads = ref([])
const sheets = ref([])
const currentSheet = ref('')
const sheetData = ref([])
const activeCharts = ref([])
const chartRefs = ref([])

const API_BASE = 'http://localhost:8000'

const fetchData = async () => {
  try {
    const [yRes, sRes, sheetsRes] = await Promise.all([
      axios.get(`${API_BASE}/yields`),
      axios.get(`${API_BASE}/spreads`),
      axios.get(`${API_BASE}/sheets`)
    ])
    yields.value = yRes.data
    spreads.value = sRes.data
    sheets.value = sheetsRes.data
    
    if (sheets.value.length && !currentSheet.value) {
      currentSheet.value = sheets.value.includes('收益率曲线') ? '收益率曲线' : sheets.value[0]
      await fetchSheetData(currentSheet.value)
    }
  } catch (err) {
    console.error('Failed to fetch data', err)
  }
}

const fetchSheetData = async (name) => {
  currentSheet.value = name
  try {
    const res = await axios.get(`${API_BASE}/sheets/${encodeURIComponent(name)}`)
    sheetData.value = res.data
    await nextTick()
    initDynamicCharts()
  } catch (err) {
    console.error('Failed to fetch sheet data', err)
  }
}

const getStatusColor = (val, header) => {
  if (val === null || val === undefined) return ''
  const num = parseFloat(val)
  if (isNaN(num)) return ''
  if (header.includes('分位数') || (num <= 1 && num >= 0 && (header.includes('水平') || header.includes('率')))) {
    if (num >= 0.9) return 'text-rose-500 font-bold bg-rose-500/10'
    if (num <= 0.1) return 'text-emerald-400 font-bold bg-emerald-400/10'
    if (num >= 0.75) return 'text-orange-400'
    if (num <= 0.25) return 'text-cyan-400'
  }
  return ''
}

const initDynamicCharts = () => {
  // Clear old charts
  activeCharts.value.forEach(c => c.dispose())
  activeCharts.value = []

  const chartContainers = document.querySelectorAll('.dynamic-chart')
  chartContainers.forEach((el, index) => {
    const chart = echarts.init(el)
    activeCharts.value.push(chart)
    
    // Custom logic per sheet
    if (currentSheet.value === '收益率曲线') {
      renderYieldCurve(chart, index)
    } else if (currentSheet.value.includes('利差') || currentSheet.value.includes('基差')) {
      renderSpreadLines(chart, index)
    }
  })
}

const renderYieldCurve = (chart, index) => {
  const table = sheetData.value[index]
  if (!table || !table.data.length) return

  // Try to find columns for X and Y
  const keys = Object.keys(table.data[0])
  const xKey = keys.find(k => k.includes('期限')) || keys[0]
  const yKey = keys.find(k => k.includes('收益率')) || keys[1]

  chart.setOption({
    title: { text: table.title, textStyle: { color: '#cbd5e1', fontSize: 14 } },
    tooltip: { trigger: 'axis' },
    grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
    xAxis: { type: 'category', data: table.data.map(d => d[xKey]), axisLine: { lineStyle: { color: '#475569' } } },
    yAxis: { type: 'value', scale: true, axisLine: { lineStyle: { color: '#475569' } }, splitLine: { lineStyle: { color: '#1e293b' } } },
    series: [{
      data: table.data.map(d => d[yKey]),
      type: 'line', smooth: true,
      itemStyle: { color: '#38bdf8' },
      areaStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{ offset: 0, color: 'rgba(56, 189, 248, 0.2)' }, { offset: 1, color: 'transparent' }]) }
    }]
  })
}

const renderSpreadLines = (chart, index) => {
  const table = sheetData.value[index]
  if (!table || !table.data.length) return

  const keys = Object.keys(table.data[0])
  const xKey = keys[0]
  const yKey = keys.find(k => k.includes('利差') || k.includes('基差') || k.includes('水平')) || keys[1]

  chart.setOption({
    title: { text: table.title, textStyle: { color: '#cbd5e1', fontSize: 14 } },
    tooltip: { trigger: 'axis' },
    xAxis: { type: 'category', data: table.data.map(d => d[xKey]), axisLine: { lineStyle: { color: '#475569' } } },
    yAxis: { type: 'value', scale: true, splitLine: { lineStyle: { color: '#1e293b' } } },
    series: [{
      data: table.data.map(d => d[yKey]),
      type: 'bar', itemStyle: { color: '#818cf8' }
    }]
  })
}

onMounted(() => {
  fetchData()
  window.addEventListener('resize', () => activeCharts.value.forEach(c => c.resize()))
})
</script>

